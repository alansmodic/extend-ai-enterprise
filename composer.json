{
	"name": "extend-ai/enterprise",
	"description": "Enterprise governance wrapper around the WordPress AI plugin.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.1"
	},
	"require-dev": {
		"phpunit/phpunit":              "^9.6",
		"yoast/phpunit-polyfills":      "^2.0",
		"squizlabs/php_codesniffer":    "^3.10"
	},
	"scripts": {
		"test":         "phpunit --testsuite=contract",
		"test:unit":    "phpunit --testsuite=unit",
		"test:contract": "phpunit --testsuite=contract"
	}
}
